<Window x:Class="MyPOE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Assistant"
        Height="720" Width="1100"
        MinHeight="520" MinWidth="850"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <Window.Resources>
        <Style x:Key="TopicButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#153655"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#86E24B"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0033E2"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#86E24B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SendButton" TargetType="Button">
            <Setter Property="Background" Value="#0033E2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2955E6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#002199"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VoiceButton" TargetType="Button">
            <Setter Property="Background" Value="#153655"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A436B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0D243A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0A2540">
            <DockPanel>

                <Border DockPanel.Dock="Top" Padding="20,24" BorderBrush="#153655" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="32" Height="32" Fill="#0033E2" Margin="0,0,12,0"/>

                        <TextBlock Text="CyberBot"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#FFFFFF"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom" Padding="16,20" BorderBrush="#153655" BorderThickness="0,1,0,0">
                    <Button x:Name="btnVoice" Content="  Play Voice Greeting"
                            Style="{StaticResource VoiceButton}"
                            Click="BtnVoice_Click"/>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,16,0,8">

                        <TextBlock Text="Cybersecurity Topics"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#7A93AA"
                                   FontFamily="Segoe UI"
                                   Margin="20,0,0,8" TextTrimming="CharacterEllipsis"/>

                        <Button Content="  Password Safety"
                                Style="{StaticResource TopicButton}"
                                Click="TopicButton_Click" Tag="password"/>
                        <Button Content="  Phishing"
                                Style="{StaticResource TopicButton}"
                                Click="TopicButton_Click" Tag="phishing"/>
                        <Button Content="  Two-Factor Auth (2FA)"
                                Style="{StaticResource TopicButton}"
                                Click="TopicButton_Click" Tag="2fa"/>
                        <Button Content="  Viruses &amp; Malware"
                                Style="{StaticResource TopicButton}"
                                Click="TopicButton_Click" Tag="viruses"/>
                        <Button Content="  Scams &amp; Fraud"
                                Style="{StaticResource TopicButton}"
                                Click="TopicButton_Click" Tag="scam"/>
                        <Button Content="  Privacy"
                                Style="{StaticResource TopicButton}"
                                Click="TopicButton_Click" Tag="privacy"/>

                        <TextBlock Text="Tools &amp; Activities"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#7A93AA"
                                   FontFamily="Segoe UI"
                                   Margin="20,16,0,8" TextTrimming="CharacterEllipsis"/>

                        <Button Content="  View My Tasks"
                                Style="{StaticResource TopicButton}"
                                Click="Action_Click" Tag="tasks"/>
                        <Button Content="  Cyber Quiz"
                                Style="{StaticResource TopicButton}"
                                Click="Action_Click" Tag="quiz"/>
                        <Button Content="  Activity Log"
                                Style="{StaticResource TopicButton}"
                                Click="Action_Click" Tag="log"/>

                        <Border Height="1" Background="#153655" Margin="20,20,20,16"/>

                        <TextBlock Text="User Memory"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#7A93AA"
                                   FontFamily="Segoe UI"
                                   Margin="20,0,0,8"/>

                        <Border Background="#0D2B4A" CornerRadius="8" Padding="16" Margin="20,4,20,0">
                            <StackPanel x:Name="pnlMemory">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="Name: " Foreground="#A0B5CA" FontSize="12" FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="txtMemoryName" Text="—" Foreground="#FFFFFF" FontSize="12" FontFamily="Segoe UI"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="Age: " Foreground="#A0B5CA" FontSize="12" FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="txtMemoryAge" Text="—" Foreground="#FFFFFF" FontSize="12" FontFamily="Segoe UI"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="Interest: " Foreground="#A0B5CA" FontSize="12" FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="txtMemoryInterest" Text="—" Foreground="#FFFFFF" FontSize="12" FontFamily="Segoe UI"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#0D2B4A" CornerRadius="8" Padding="12" Margin="20,12,20,0">
                            <StackPanel>
                                <TextBlock Text="Tasks" FontSize="11" FontWeight="SemiBold" Foreground="#7A93AA" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <ListBox x:Name="lstTasks" Background="#0D2B4A" BorderThickness="0" Foreground="#FFFFFF" HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0A2B44" CornerRadius="6" Padding="8" Margin="0,4,0,4">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12" Foreground="#A0B5CA"/>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                                        <TextBlock Text="{Binding ReminderDate, StringFormat='Reminder: {0:yyyy-MM-dd HH:mm}'}" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <Button Content="Complete" Click="BtnCompleteTask_Click" Tag="{Binding Id}" Margin="0,0,6,0"/>
                                                        <Button Content="Delete" Click="BtnDeleteTask_Click" Tag="{Binding Id}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Background="#F5F6FA">
            <Border Background="#FFFFFF" Margin="30" CornerRadius="12"
                    BorderBrush="#E5E7EB" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="15" ShadowDepth="4"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FFFFFF" Padding="24,16"
                            BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" CornerRadius="12,12,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Chat Window"
                                       FontSize="18" FontWeight="SemiBold" 
                                       Foreground="#1A1F36" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <Ellipse Width="8" Height="8" Fill="#10B981" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Online"
                                       FontSize="12" Foreground="#6B7280" FontFamily="Segoe UI"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer x:Name="chatScroll" Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#FAFBFC"
                                  Padding="0">
                        <StackPanel x:Name="chatPanel" Margin="24,16,24,16"/>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#FFFFFF"
                            BorderBrush="#E5E7EB" BorderThickness="0,1,0,0"
                            Padding="24,20" CornerRadius="0,0,12,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#F9FAFB"
                                    CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1"
                                    Margin="0,0,12,0">
                                <TextBox x:Name="txtInput"
                                         Background="Transparent"
                                         Foreground="#1F2937"
                                         CaretBrush="#0033E2"
                                         BorderThickness="0"
                                         Padding="16,12"
                                         FontSize="14"
                                         FontFamily="Segoe UI"
                                         VerticalContentAlignment="Center"
                                         AcceptsReturn="False"
                                         KeyDown="TxtInput_KeyDown"
                                         Tag="Type a message here..."/>
                            </Border>

                            <Button Grid.Column="1" x:Name="btnSend"
                                    Content="Send"
                                    Style="{StaticResource SendButton}"
                                    Click="BtnSend_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
